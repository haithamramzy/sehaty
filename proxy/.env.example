# ── Copy to .env and fill in ─────────────────────────────────────────────────

# MiniMax API key — NEVER put this in the app. It lives only on the VPS.
MINIMAX_API_KEY=

# MiniMax OpenAI-compatible chat completions endpoint + models.
# Adjust to whatever your MiniMax account/region exposes.
MINIMAX_BASE_URL=https://api.minimax.io/v1/text/chatcompletion_v2
MINIMAX_CHAT_MODEL=MiniMax-Text-01
MINIMAX_VISION_MODEL=MiniMax-VL-01

# Shared secret between the app and this proxy. Generate one:
#   openssl rand -hex 32
# The app sends it as:  Authorization: Bearer <APP_TOKEN>
APP_TOKEN=

# Port the proxy listens on (nginx reverse-proxies 443 → this).
PORT=8787

# Set to 1 to serve canned responses without calling MiniMax at all —
# lets you test the app ↔ proxy plumbing before the real key is in place.
MOCK_AI=0
